{
	"name": "httpstart",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"backend-prod": "vite build && node src/backend/index.ts 29222 ui",
		"backend-dev": "tsx watch src/backend/index.ts 29222 ui",
		"backend-build": "esbuild src/backend/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.19",
		"esbuild": "0.28.0",
		"eslint": "^10.3.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tsx": "^4.22.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12"
	},
	"dependencies": {
		"@delfi-ch/linux-os-info-esmodule": "^2.0.3",
		"@sveltestrap/sveltestrap": "^7.1.0",
		"axios": "^1.16.0",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"express-htmshell": "^0.8.1",
		"lit": "^3.3.2",
		"svelte-htmshell": "^0.9.1"
	}
}
